---
import { useTranslations } from "@i18n/ui";
import { DEFAULT_LOCALE, getLangTag, type Locale } from "@i18n/utils";

interface Props {
  pubDatetime: string | Date;
  modDatetime?: string | Date | null;
  size?: "sm" | "lg";
  className?: string;
  locale?: Locale;
}

const {
  pubDatetime,
  modDatetime,
  size = "sm",
  className = "",
  locale = DEFAULT_LOCALE,
} = Astro.props;
const t = useTranslations(locale);

const isUpdated = modDatetime && new Date(modDatetime) > new Date(pubDatetime);
const myDatetime = new Date(isUpdated ? modDatetime! : pubDatetime);
const dateStr = myDatetime.toLocaleDateString(getLangTag(locale), {
  year: "numeric",
  month: "short",
  day: "numeric",
});
const iso = myDatetime.toISOString();
const sizeText = size === "sm" ? "text-sm" : "text-base";
const svgScale = size === "sm" ? "scale-90" : "scale-100";
---

<div class:list={["flex items-center space-x-2 text-skin-base/75", className]}>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class:list={[
      svgScale,
      "inline-block h-6 w-6 min-w-[1.375rem] fill-skin-accent/85",
    ]}
    aria-hidden="true"
  >
    <path
      d="M7 11h2v2H7zm0 4h2v2H7zm4-4h2v2h-2zm0 4h2v2h-2zm4-4h2v2h-2zm0 4h2v2h-2z"
    >
    </path>
    <path
      d="M5 22h14c1.103 0 2-.897 2-2V6c0-1.103-.897-2-2-2h-2V2h-2v2H9V2H7v2H5c-1.103 0-2 .897-2 2v14c0 1.103.897 2 2 2zM19 8l.001 12H5V8h14z"
    >
    </path>
  </svg>
  {
    isUpdated ? (
      <span class:list={[sizeText, "font-mono"]}>{t("datetime.updated")}</span>
    ) : (
      <span class="sr-only">{t("datetime.published")}</span>
    )
  }
  <span class:list={[sizeText, "font-mono"]}
    ><time datetime={iso}>{dateStr}</time></span
  >
</div>

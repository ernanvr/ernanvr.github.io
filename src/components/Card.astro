---
import { slugifyStr } from "@utils/slugify";
import { type Locale } from "@i18n/utils";
import Datetime from "./Datetime.astro";

interface Props {
  href?: string;
  frontmatter: {
    title: string;
    description: string;
    pubDatetime: string | Date;
    modDatetime?: string | Date | null;
  };
  secHeading?: boolean;
  locale?: Locale;
}

const { href, frontmatter, secHeading = true, locale = "en" } = Astro.props;
const { title, pubDatetime, modDatetime, description } = frontmatter;

const headingClass =
  "text-xl font-semibold decoration-dashed underline-offset-4 hover:underline";
const headingStyle = `view-transition-name: ${slugifyStr(title)}`;
const Heading = secHeading ? "h2" : "h3";
---

<li class="paper-surface paper-surface-hover my-6 p-5 sm:p-6">
  <a
    href={href}
    class="text-skin-accent inline-block decoration-dashed focus-visible:no-underline focus-visible:underline-offset-0"
  >
    <Heading class={headingClass} style={headingStyle}>{title}</Heading>
  </a>
  <Datetime
    pubDatetime={pubDatetime}
    modDatetime={modDatetime}
    className="mt-2"
    locale={locale}
  />
  <p class="text-skin-base/90 mt-3 text-[0.98rem] leading-7">{description}</p>
</li>

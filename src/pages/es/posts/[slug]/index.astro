---
import type { CollectionEntry } from "astro:content";
import PostDetails from "@layouts/PostDetails.astro";
import { getPostSlug } from "@utils/slugify";
import { getSortedPostsByLocale } from "@utils/posts";

export interface Props {
  post: CollectionEntry<"blog">;
}

export async function getStaticPaths() {
  const posts = await getSortedPostsByLocale("es");

  const postResult = posts.map(post => ({
    params: { slug: getPostSlug(post.id) },
    props: { post },
  }));

  return postResult;
}

const { post } = Astro.props;

const sortedPosts = await getSortedPostsByLocale("es");
---

<PostDetails post={post} posts={sortedPosts} locale="es" />

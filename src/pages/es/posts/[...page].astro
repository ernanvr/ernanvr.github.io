---
import Posts from "@layouts/Posts.astro";
import type { GetStaticPaths } from "astro";
import { getPostsStaticPaths } from "@utils/staticPaths";

export const getStaticPaths = (async options =>
  getPostsStaticPaths("es", options)) satisfies GetStaticPaths;
---

<Posts page={Astro.props.page} locale="es" />

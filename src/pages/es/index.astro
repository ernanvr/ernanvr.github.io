---
import Index from "@layouts/Index.astro";
import { getSortedPostsByLocale } from "@utils/posts";

const locale = "es";
const sortedPosts = await getSortedPostsByLocale(locale);
---

<Index
  locale={locale}
  heroTitle="Hola, soy Ernán."
  heroBody="Soy un emprendedor de El Salvador enfocado en IA e impacto de largo plazo. Este blog es donde comparto las ideas que dan forma a cómo pienso y construyo. Espero que me ayude a conectar con personas alrededor del mundo que compartan valores, visión y pasión similares."
  sortedPosts={sortedPosts}
/>

---
import type { CollectionEntry } from "astro:content";
import PostDetails from "@layouts/PostDetails.astro";
import { getSortedPostsByLocale } from "@utils/posts";
import { getPostDetailsStaticPaths } from "@utils/staticPaths";

export interface Props {
  post: CollectionEntry<"blog">;
}

export async function getStaticPaths() {
  return getPostDetailsStaticPaths("en");
}

const sortedPosts = await getSortedPostsByLocale("en");
---

<PostDetails post={Astro.props.post} posts={sortedPosts} locale="en" />

---
import Search from "@layouts/Search.astro";
import { getSortedPostsByLocale } from "@utils/posts";
import { getPostSlug } from "@utils/slugify";
import type { SearchItem } from "@components/Search.astro";

// Retrieve all published articles
const sortedPosts = await getSortedPostsByLocale("en");

// List of items to search in
const searchList: SearchItem[] = sortedPosts.map(({ data, id }) => ({
  title: data.title,
  description: data.description,
  pubDatetime: data.pubDatetime.toISOString(),
  modDatetime: data.modDatetime ? data.modDatetime.toISOString() : null,
  slug: getPostSlug(id),
}));
---

<Search locale="en" {searchList} />

---
import Index from "@layouts/Index.astro";
import { getSortedPostsByLocale } from "@utils/posts";

const locale = "en";
const sortedPosts = await getSortedPostsByLocale(locale);
---

<Index
  locale={locale}
  heroTitle="Hi, I'm Ernán."
  heroBody="I'm an entrepreneur from El Salvador focused on AI and long-term impact. This blog is where I share the ideas that shape how I think and build. I hope it helps me connect with people around the world who share similar values, vision and passion."
  sortedPosts={sortedPosts}
/>

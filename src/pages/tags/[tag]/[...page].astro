---
import TagPosts from "@layouts/TagPosts.astro";
import type { GetStaticPaths } from "astro";
import { getTagPostsStaticPaths } from "@utils/staticPaths";

export const getStaticPaths = (async options =>
  getTagPostsStaticPaths("en", options)) satisfies GetStaticPaths;
---

<TagPosts
  page={Astro.props.page}
  tag={Astro.params.tag}
  tagName={Astro.props.tagName}
  locale="en"
/>

---
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Layout from "@layouts/Layout.astro";
import Main from "@layouts/Main.astro";
import Tag from "@components/Tag.astro";
import { useTranslations } from "@i18n/ui";
import { SITE } from "@config";
import type { Locale } from "@i18n/utils";

export interface Props {
  locale: Locale;
  tags: { tag: string; tagName: string }[];
}

const { locale, tags } = Astro.props;
const t = useTranslations(locale);
---

<Layout title={`${t("page.tags.title")} | ${SITE.title}`}>
  <Header activeNav="tags" />
  <Main pageTitle={t("page.tags.title")} pageDesc={t("page.tags.desc")}>
    <ul class="flex flex-wrap gap-y-2">
      {tags.map(({ tag }) => <Tag {tag} size="lg" {locale} />)}
    </ul>
  </Main>
  <Footer />
</Layout>

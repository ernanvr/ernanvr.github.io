---
import Card from "@components/Card.astro";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import { SITE } from "@config";
import { getLocalizedPath, type Locale } from "@i18n/utils";
import Layout from "@layouts/Layout.astro";
import Main from "@layouts/Main.astro";
import { useTranslations } from "@i18n/ui";
import getPostsByGroupCondition from "@utils/getPostsByGroupCondition";
import { getPostSlug } from "@utils/slugify";
import monthName from "@utils/monthName";
import type { CollectionEntry } from "astro:content";

export interface Props {
  locale: Locale;
  archivedPosts: CollectionEntry<"blog">[];
}

const { locale, archivedPosts } = Astro.props;
const t = useTranslations(locale);
const postPath = getLocalizedPath(locale, "posts");
---

<Layout title={`${t("page.archives.title")} | ${SITE.title}`}>
  <Header activeNav="archives" />
  <Main pageTitle={t("page.archives.title")} pageDesc={t("page.archives.desc")}>
    {
      archivedPosts.length === 0 ? (
        <p
          class="text-skin-base text-center text-lg"
          set:html={"\n" + t("page.archives.empty") + "\n"}
        />
      ) : (
        Object.entries(
          getPostsByGroupCondition(archivedPosts, post =>
            post.data.pubDatetime.getFullYear()
          )
        )
          .sort(([yearA], [yearB]) => Number(yearB) - Number(yearA))
          .map(([year, yearGroup]) => (
            <div class="mb-10">
              <span class="text-skin-accent font-mono text-2xl font-bold">
                {year}
              </span>
              <sup class="text-skin-base/75 ml-1 font-mono text-xs">
                {yearGroup.length}
              </sup>
              {Object.entries(
                getPostsByGroupCondition(
                  yearGroup,
                  post => post.data.pubDatetime.getMonth() + 1
                )
              )
                .sort(([monthA], [monthB]) => Number(monthB) - Number(monthA))
                .map(([month, monthGroup]) => (
                  <div class="flex flex-col sm:flex-row sm:gap-4">
                    <div class="mt-6 min-w-36 text-lg sm:my-6">
                      <span class="font-mono font-bold">
                        {monthName(locale, Number(month))}
                      </span>
                      <sup class="text-skin-base/75 ml-1 font-mono text-xs">
                        {monthGroup.length}
                      </sup>
                    </div>
                    <ul>
                      {monthGroup.map(({ data, id }) => (
                        <Card
                          href={`${postPath}${getPostSlug(id)}/`}
                          frontmatter={data}
                          locale={locale}
                        />
                      ))}
                    </ul>
                  </div>
                ))}
            </div>
          ))
      )
    }
  </Main>

  <Footer />
</Layout>
